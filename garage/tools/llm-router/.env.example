# Copy this file to ".env" and fill in what you have. You don't need all of them.
#
# The free local model is the whole point — set OLLAMA_BASE_URL and you get the
# money-saving even with no cloud keys at all. Add the cloud keys when you want
# the paid lanes (balanced/smart) and automatic backup.

# Your free local model (Ollama). On your own garage server this is usually:
OLLAMA_BASE_URL=http://localhost:11434/v1

# Optional: how many seconds to wait on the local model before falling back (default 20s).
# OLLAMA_TIMEOUT_MS=20000

# Optional — turns on the "balanced" lane (cheap cloud model) and acts as backup.
# OPENAI_API_KEY=sk-...

# Optional — turns on the "smart" lane (Claude) for the hard jobs.
# ANTHROPIC_API_KEY=sk-ant-...

# Which port the router listens on (default 3001).
# PORT=3001
